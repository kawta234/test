<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LUXE ESSENCE — Parfums de Prestige</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --dark: #0D0B08;
    --dark2: #1A1610;
    --dark3: #252017;
    --cream: #F5F0E8;
    --cream2: #EDE5D4;
    --text: #F0EBE0;
    --text-muted: #9A8F7A;
    --whatsapp: #25D366;
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Jost', sans-serif;
    background: var(--dark);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 5%;
    background: linear-gradient(to bottom, rgba(13,11,8,0.95), transparent);
    backdrop-filter: blur(8px);
  }
  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 300; letter-spacing: 0.3em;
    color: var(--gold); text-decoration: none;
  }
  .logo span { font-style: italic; font-weight: 600; }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none; transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-order-btn {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.55rem 1.4rem; border: 1px solid var(--gold);
    color: var(--gold); background: transparent; cursor: pointer;
    text-decoration: none; transition: all 0.3s;
  }
  .nav-order-btn:hover { background: var(--gold); color: var(--dark); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(201,168,76,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 60%, rgba(201,168,76,0.05) 0%, transparent 50%),
      var(--dark);
    padding: 8rem 5% 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 39px,
      rgba(201,168,76,0.03) 39px,
      rgba(201,168,76,0.03) 40px
    );
  }
  .hero-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 9vw, 7.5rem); font-weight: 300; line-height: 0.95;
    letter-spacing: 0.05em; margin-bottom: 1.5rem;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 0.85rem; font-weight: 300; letter-spacing: 0.15em;
    color: var(--text-muted); max-width: 400px; margin: 0 auto 3rem; line-height: 1.8;
  }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    padding: 0.9rem 2.5rem; background: var(--gold); color: var(--dark);
    font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
    font-weight: 500; border: none; cursor: pointer; text-decoration: none;
    transition: all 0.3s; display: inline-block;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-outline {
    padding: 0.9rem 2.5rem; background: transparent; color: var(--text);
    font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
    border: 1px solid rgba(240,235,224,0.3); cursor: pointer; text-decoration: none;
    transition: all 0.3s; display: inline-block;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  /* ── SECTION HEADERS ── */
  .section-header { text-align: center; padding: 5rem 5% 3rem; }
  .section-label {
    font-size: 0.6rem; letter-spacing: 0.5em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem; display: block;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 300;
    letter-spacing: 0.05em; line-height: 1.1;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .divider {
    width: 60px; height: 1px; background: var(--gold);
    margin: 1.5rem auto 0;
  }

  /* ── PRODUCTS ── */
  .products { padding: 2rem 5% 6rem; }
  .category-tabs {
    display: flex; gap: 0; justify-content: center; margin-bottom: 3rem;
    border: 1px solid rgba(201,168,76,0.3);
    width: fit-content; margin: 0 auto 3rem;
  }
  .tab-btn {
    padding: 0.7rem 2rem; font-size: 0.7rem; letter-spacing: 0.2em;
    text-transform: uppercase; background: transparent; color: var(--text-muted);
    border: none; cursor: pointer; transition: all 0.3s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--gold); color: var(--dark);
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
  }
  .product-card {
    background: var(--dark2);
    position: relative; overflow: hidden; cursor: pointer;
    transition: transform 0.4s;
  }
  .product-card:hover { transform: translateY(-4px); }
  .product-card:hover .product-overlay { opacity: 1; }
  .product-img {
    width: 100%; aspect-ratio: 3/4; object-fit: cover;
    background: linear-gradient(135deg, var(--dark3), var(--dark2));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 5rem;
    color: rgba(201,168,76,0.2); font-style: italic;
    position: relative; overflow: hidden;
  }
  .product-img-inner {
    width: 100%; aspect-ratio: 3/4;
    background: linear-gradient(160deg, #1e1a12 0%, #0f0d09 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem;
  }
  .bottle-icon {
    width: 80px; height: 120px;
    position: relative; display: flex; flex-direction: column; align-items: center;
  }
  .bottle-neck {
    width: 18px; height: 28px;
    background: linear-gradient(to right, rgba(201,168,76,0.6), rgba(201,168,76,0.3), rgba(201,168,76,0.6));
    border-radius: 3px 3px 0 0;
  }
  .bottle-cap {
    width: 24px; height: 10px;
    background: var(--gold);
    border-radius: 2px; margin-bottom: 2px;
  }
  .bottle-body {
    width: 70px; height: 90px;
    background: linear-gradient(135deg, rgba(201,168,76,0.15), rgba(201,168,76,0.05), rgba(201,168,76,0.2));
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 0 0 8px 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .bottle-label-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); text-align: center;
  }
  .badge-new, .badge-promo {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.3rem 0.7rem; font-weight: 500; z-index: 2;
  }
  .badge-new { background: var(--gold); color: var(--dark); }
  .badge-promo { background: #8B1A1A; color: #FFB3B3; }
  .product-overlay {
    position: absolute; inset: 0; background: rgba(13,11,8,0.7);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.3s;
  }
  .btn-order-quick {
    padding: 0.75rem 1.8rem; background: var(--gold); color: var(--dark);
    font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase;
    font-weight: 500; border: none; cursor: pointer;
    transition: background 0.2s;
  }
  .btn-order-quick:hover { background: var(--gold-light); }
  .product-info { padding: 1.2rem 1.4rem; }
  .product-category {
    font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.4rem;
  }
  .product-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 400; letter-spacing: 0.02em;
    margin-bottom: 0.3rem;
  }
  .product-desc {
    font-size: 0.72rem; color: var(--text-muted); line-height: 1.6;
    margin-bottom: 1rem;
  }
  .product-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1rem; border-top: 1px solid rgba(201,168,76,0.15);
  }
  .product-price {
    font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 400;
  }
  .product-price .currency { font-size: 0.8rem; color: var(--text-muted); }
  .product-price .old-price {
    font-size: 0.9rem; color: var(--text-muted);
    text-decoration: line-through; margin-right: 0.5rem;
  }
  .product-price .new-price { color: var(--gold); }
  .product-ml { font-size: 0.65rem; color: var(--text-muted); letter-spacing: 0.1em; }
  .btn-add-cart {
    width: 36px; height: 36px; border: 1px solid rgba(201,168,76,0.4);
    background: transparent; color: var(--gold); font-size: 1rem;
    cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center;
  }
  .btn-add-cart:hover { background: var(--gold); color: var(--dark); }

  /* ── WHY US ── */
  .features {
    padding: 5rem 5%;
    background: linear-gradient(to bottom, var(--dark2), var(--dark));
  }
  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem; margin-top: 3rem; text-align: center;
  }
  .feature-icon {
    width: 56px; height: 56px; margin: 0 auto 1.2rem;
    border: 1px solid rgba(201,168,76,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
  }
  .feature-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; margin-bottom: 0.5rem;
  }
  .feature-text {
    font-size: 0.78rem; color: var(--text-muted); line-height: 1.7;
  }

  /* ── ORDER SECTION ── */
  #commander { padding: 5rem 5% 6rem; }
  .order-container {
    max-width: 700px; margin: 0 auto;
    background: var(--dark2); border: 1px solid rgba(201,168,76,0.2);
    padding: 3rem;
  }
  .order-method-tabs {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-bottom: 2.5rem;
  }
  .method-btn {
    padding: 1rem; background: var(--dark3); border: none;
    color: var(--text-muted); cursor: pointer;
    font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
    transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  }
  .method-btn.active { background: var(--gold); color: var(--dark); }
  .method-btn:not(.active):hover { background: rgba(201,168,76,0.1); color: var(--gold); }
  .method-icon { font-size: 1rem; }
  .form-panel { display: none; }
  .form-panel.active { display: block; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { margin-bottom: 1.2rem; }
  .form-group label {
    display: block; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 0.5rem;
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%; padding: 0.75rem 1rem;
    background: var(--dark3); border: 1px solid rgba(201,168,76,0.2);
    color: var(--text); font-family: 'Jost', sans-serif; font-size: 0.88rem;
    outline: none; transition: border-color 0.3s; appearance: none;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    border-color: var(--gold);
  }
  .form-group select option { background: var(--dark2); }
  .form-group textarea { resize: vertical; min-height: 80px; }
  .payment-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.2rem; border: 1px solid rgba(201,168,76,0.3);
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); margin: 0.5rem 0 1.5rem; background: rgba(201,168,76,0.05);
  }
  .btn-submit {
    width: 100%; padding: 1rem; background: var(--gold); color: var(--dark);
    border: none; font-size: 0.78rem; letter-spacing: 0.3em; text-transform: uppercase;
    font-weight: 500; cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif;
  }
  .btn-submit:hover { background: var(--gold-light); }
  .whatsapp-content { text-align: center; padding: 2rem 0; }
  .wa-number {
    font-family: 'Cormorant Garamond', serif; font-size: 2.5rem;
    color: var(--whatsapp); margin: 1rem 0;
    direction: ltr; letter-spacing: 0.05em;
  }
  .wa-hint { font-size: 0.8rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 2rem; }
  .btn-whatsapp {
    display: inline-flex; align-items: center; gap: 0.7rem;
    padding: 1rem 2.5rem; background: var(--whatsapp); color: #fff;
    border: none; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; cursor: pointer; transition: all 0.3s; text-decoration: none;
    font-family: 'Jost', sans-serif;
  }
  .btn-whatsapp:hover { background: #1EAF55; transform: translateY(-2px); }
  .wa-icon { font-size: 1.2rem; }
  .form-note { font-size: 0.7rem; color: var(--text-muted); margin-top: 1rem; text-align: center; }

  /* ── SUCCESS MODAL ── */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(13,11,8,0.92); align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: var(--dark2); border: 1px solid rgba(201,168,76,0.4);
    padding: 3rem; max-width: 420px; width: 90%; text-align: center;
  }
  .modal-icon {
    width: 64px; height: 64px; border: 1px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; margin: 0 auto 1.5rem;
  }
  .modal-title {
    font-family: 'Cormorant Garamond', serif; font-size: 2rem;
    margin-bottom: 0.8rem;
  }
  .modal-text { font-size: 0.82rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 2rem; }
  .btn-close-modal {
    padding: 0.75rem 2.5rem; border: 1px solid var(--gold); background: transparent;
    color: var(--gold); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    cursor: pointer; transition: all 0.3s; font-family: 'Jost', sans-serif;
  }
  .btn-close-modal:hover { background: var(--gold); color: var(--dark); }

  /* ── FOOTER ── */
  footer {
    padding: 3rem 5%; border-top: 1px solid rgba(201,168,76,0.15);
    display: flex; align-items: center; justify-content: space-between; flex-wrap: gap;
    gap: 1rem;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 300; letter-spacing: 0.3em; color: var(--gold);
  }
  .footer-copy { font-size: 0.7rem; color: var(--text-muted); }

  /* ── SELECTED PRODUCT BANNER ── */
  .selected-product-banner {
    background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.25);
    padding: 0.8rem 1.2rem; margin-bottom: 1.5rem;
    display: none; align-items: center; justify-content: space-between;
    font-size: 0.78rem;
  }
  .selected-product-banner.show { display: flex; }
  .selected-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: var(--gold); }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .form-row { grid-template-columns: 1fr; }
    .order-container { padding: 2rem 1.5rem; }
    .hero h1 { font-size: 3rem; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="logo">LUXE <span>Essence</span></a>
  <ul class="nav-links">
    <li><a href="#produits">Produits</a></li>
    <li><a href="#avantages">Avantages</a></li>
    <li><a href="#commander">Commander</a></li>
  </ul>
  <a href="#commander" class="nav-order-btn">Commander</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div>
    <p class="hero-eyebrow">✦ Parfums de marque personnelle ✦</p>
    <h1>L'Art de<br>la <em>Fragrance</em><br>Pure</h1>
    <p class="hero-sub">Des parfums exclusifs, élaborés avec les essences les plus rares. Livraison au Maroc — Paiement à la livraison.</p>
    <div class="hero-btns">
      <a href="#produits" class="btn-primary">Découvrir la Collection</a>
      <a href="#commander" class="btn-outline">Commander Maintenant</a>
    </div>
  </div>
</section>

<!-- PRODUCTS -->
<section id="produits">
  <div class="section-header">
    <span class="section-label">Notre Collection</span>
    <h2 class="section-title">Parfums <em>d'Exception</em></h2>
    <div class="divider"></div>
  </div>
  <div class="products">
    <div class="category-tabs">
      <button class="tab-btn active" onclick="filterProducts('tous', this)">Tous</button>
      <button class="tab-btn" onclick="filterProducts('homme', this)">Homme</button>
      <button class="tab-btn" onclick="filterProducts('femme', this)">Femme</button>
      <button class="tab-btn" onclick="filterProducts('mixte', this)">Mixte</button>
    </div>
    <div class="products-grid" id="productsGrid">
      <!-- Products injected by JS -->
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features" id="avantages">
  <div class="section-header">
    <span class="section-label">Pourquoi Nous Choisir</span>
    <h2 class="section-title">Notre <em>Engagement</em></h2>
    <div class="divider"></div>
  </div>
  <div class="features-grid">
    <div>
      <div class="feature-icon">🚚</div>
      <h3 class="feature-title">Livraison Rapide</h3>
      <p class="feature-text">Livraison dans tout le Maroc en 24 à 72h. Paiement uniquement à la réception.</p>
    </div>
    <div>
      <div class="feature-icon">🌹</div>
      <h3 class="feature-title">Essences Rares</h3>
      <p class="feature-text">Chaque parfum est composé des meilleures matières premières soigneusement sélectionnées.</p>
    </div>
    <div>
      <div class="feature-icon">🎁</div>
      <h3 class="feature-title">Emballage Luxueux</h3>
      <p class="feature-text">Chaque commande est emballée avec soin dans un coffret élégant, prêt à offrir.</p>
    </div>
    <div>
      <div class="feature-icon">✓</div>
      <h3 class="feature-title">100% Authentique</h3>
      <p class="feature-text">Tous nos parfums sont certifiés et garantis authentiques. Satisfaction assurée.</p>
    </div>
  </div>
</section>

<!-- ORDER -->
<section id="commander">
  <div class="section-header">
    <span class="section-label">Passer Commande</span>
    <h2 class="section-title">Comment <em>Commander</em></h2>
    <div class="divider"></div>
  </div>
  <div style="padding: 2rem 5% 6rem;">
    <div class="order-container">
      <div class="order-method-tabs">
        <button class="method-btn active" onclick="switchMethod('form', this)">
          <span class="method-icon">📋</span> Formulaire
        </button>
        <button class="method-btn" onclick="switchMethod('whatsapp', this)">
          <span class="method-icon">💬</span> WhatsApp
        </button>
      </div>

      <!-- FORM -->
      <div class="form-panel active" id="panel-form">
        <div class="selected-product-banner" id="selectedBanner">
          <div>
            <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.2rem">Produit sélectionné</div>
            <div class="selected-name" id="selectedName">—</div>
          </div>
          <button onclick="clearSelection()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.2rem;">×</button>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Prénom</label>
            <input type="text" id="fname" placeholder="Votre prénom" />
          </div>
          <div class="form-group">
            <label>Nom</label>
            <input type="text" id="lname" placeholder="Votre nom" />
          </div>
        </div>
        <div class="form-group">
          <label>Téléphone</label>
          <input type="tel" id="phone" placeholder="+212 6XX XXX XXX" />
        </div>
        <div class="form-group">
          <label>Ville / Région</label>
          <select id="city">
            <option value="">— Sélectionner votre ville —</option>
            <option>Casablanca</option>
            <option>Rabat</option>
            <option>Marrakech</option>
            <option>Fès</option>
            <option>Tanger</option>
            <option>Agadir</option>
            <option>Meknès</option>
            <option>Oujda</option>
            <option>Beni Mellal</option>
            <option>Khouribga</option>
            <option>Autre ville</option>
          </select>
        </div>
        <div class="form-group">
          <label>Adresse de livraison</label>
          <input type="text" id="address" placeholder="Quartier, rue, numéro..." />
        </div>
        <div class="form-group">
          <label>Produit désiré</label>
          <select id="productSelect">
            <option value="">— Choisir un parfum —</option>
            <option>Nuit Dorée — Homme 100ml</option>
            <option>Velours Rose — Femme 75ml</option>
            <option>Désert Noir — Mixte 100ml</option>
            <option>Éclat Blanc — Femme 50ml</option>
            <option>Oud Royal — Homme 100ml</option>
            <option>Iris Précieux — Femme 75ml</option>
          </select>
        </div>
        <div class="form-group">
          <label>Notes / Message (optionnel)</label>
          <textarea id="notes" placeholder="Instructions spéciales, questions..."></textarea>
        </div>

        <div class="payment-badge">
          <span>💰</span> Paiement à la livraison — aucun paiement en avance
        </div>

        <button class="btn-submit" onclick="submitOrder()">
          Confirmer la Commande
        </button>
        <p class="form-note">Vous recevrez une confirmation par SMS dans les 24h</p>
      </div>

      <!-- WHATSAPP -->
      <div class="form-panel" id="panel-whatsapp">
        <div class="whatsapp-content">
          <p style="font-size:0.8rem;color:var(--text-muted);letter-spacing:0.1em;margin-bottom:0.5rem">Contactez-nous directement sur</p>
          <p class="wa-number">+212 6XX-XXX-XXX</p>
          <p class="wa-hint">
            Envoyez-nous un message WhatsApp avec :<br>
            • Le nom du parfum souhaité<br>
            • Votre ville et adresse de livraison<br>
            • Votre nom et numéro de téléphone<br><br>
            Nous confirmons votre commande en quelques minutes.<br>
            <strong style="color:var(--gold)">Paiement à la livraison</strong> — aucun risque.
          </p>
          <a href="https://wa.me/212600000000?text=Bonjour%2C%20je%20voudrais%20commander%20un%20parfum%20LUXE%20ESSENCE.%0ANom%20du%20parfum%20%3A%20%0AVille%20%3A%20%0AAdresse%20%3A%20"
             target="_blank" class="btn-whatsapp">
            <span class="wa-icon">💬</span> Ouvrir WhatsApp
          </a>
          <div class="payment-badge" style="margin-top:1.5rem;justify-content:center">
            <span>💰</span> Paiement à la livraison garanti
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">LUXE <em style="font-style:italic">Essence</em></div>
  <p class="footer-copy">© 2025 Luxe Essence — Tous droits réservés</p>
  <p class="footer-copy">Livraison partout au Maroc 🇲🇦</p>
</footer>

<!-- SUCCESS MODAL -->
<div class="modal-overlay" id="successModal">
  <div class="modal-box">
    <div class="modal-icon">✓</div>
    <h3 class="modal-title">Commande Confirmée</h3>
    <p class="modal-text">
      Merci pour votre commande !<br>
      Notre équipe vous contactera dans les <strong style="color:var(--gold)">24 heures</strong> pour confirmer la livraison.<br><br>
      Paiement à la réception uniquement.
    </p>
    <button class="btn-close-modal" onclick="closeModal()">Fermer</button>
  </div>
</div>

<script>
const products = [
  { id:1, name:"Nuit Dorée", category:"homme", desc:"Notes de bois de santal, ambre et cuir. Une fragrance intense et envoûtante.", price:"450", oldPrice:null, ml:"100", badge:"new" },
  { id:2, name:"Velours Rose", category:"femme", desc:"Bouquet floral de rose de Bulgarie, jasmin et musc blanc. Élégance absolue.", price:"399", oldPrice:"550", ml:"75", badge:"promo" },
  { id:3, name:"Désert Noir", category:"mixte", desc:"Oud fumé, encens et épices orientales. Une aventure olfactive unique.", price:"520", oldPrice:null, ml:"100", badge:null },
  { id:4, name:"Éclat Blanc", category:"femme", desc:"Fraîcheur de bergamote, vanille de Madagascar et fleur d'oranger.", price:"320", oldPrice:null, ml:"50", badge:"new" },
  { id:5, name:"Oud Royal", category:"homme", desc:"Oud de qualité supérieure, rose noire et épices précieuses. Le luxe à l'état pur.", price:"680", oldPrice:"900", ml:"100", badge:"promo" },
  { id:6, name:"Iris Précieux", category:"femme", desc:"Iris, poudre de talc et cèdre. Une féminité délicate et raffinée.", price:"480", oldPrice:null, ml:"75", badge:null },
];

let currentFilter = 'tous';

function renderProducts(filter) {
  const grid = document.getElementById('productsGrid');
  const filtered = filter === 'tous' ? products : products.filter(p => p.category === filter);
  grid.innerHTML = filtered.map(p => `
    <div class="product-card" data-cat="${p.category}">
      ${p.badge === 'new' ? '<span class="badge-new">Nouveau</span>' : ''}
      ${p.badge === 'promo' ? '<span class="badge-promo">Promo</span>' : ''}
      <div class="product-img-inner">
        <div class="bottle-icon">
          <div class="bottle-cap"></div>
          <div class="bottle-neck"></div>
          <div class="bottle-body">
            <div class="bottle-label-text">${p.name.split(' ')[0]}<br>${p.name.split(' ')[1]||''}</div>
          </div>
        </div>
      </div>
      <div class="product-overlay">
        <button class="btn-order-quick" onclick="selectProduct('${p.name} — ${p.category.charAt(0).toUpperCase()+p.category.slice(1)} ${p.ml}ml')">Commander</button>
      </div>
      <div class="product-info">
        <p class="product-category">${p.category.charAt(0).toUpperCase()+p.category.slice(1)}</p>
        <h3 class="product-name">${p.name}</h3>
        <p class="product-desc">${p.desc}</p>
        <div class="product-footer">
          <div class="product-price">
            ${p.oldPrice ? `<span class="old-price">${p.oldPrice} MAD</span>` : ''}
            <span class="new-price">${p.price} <span class="currency">MAD</span></span>
          </div>
          <span class="product-ml">${p.ml} ml</span>
          <button class="btn-add-cart" onclick="selectProduct('${p.name} — ${p.category.charAt(0).toUpperCase()+p.category.slice(1)} ${p.ml}ml')" title="Commander">+</button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterProducts(cat, btn) {
  currentFilter = cat;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(cat);
}

function selectProduct(name) {
  document.getElementById('productSelect').value = '';
  const opts = document.getElementById('productSelect').options;
  for (let o of opts) { if (o.value === name || name.includes(o.value.split(' — ')[0])) { document.getElementById('productSelect').value = o.value; break; } }
  document.getElementById('selectedName').textContent = name;
  document.getElementById('selectedBanner').classList.add('show');
  document.getElementById('commander').scrollIntoView({ behavior: 'smooth', block: 'start' });
  switchMethod('form', document.querySelectorAll('.method-btn')[0]);
}

function clearSelection() {
  document.getElementById('selectedBanner').classList.remove('show');
  document.getElementById('productSelect').value = '';
}

function switchMethod(method, btn) {
  document.querySelectorAll('.method-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.form-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + method).classList.add('active');
}

function submitOrder() {
  const fname = document.getElementById('fname').value.trim();
  const lname = document.getElementById('lname').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const city = document.getElementById('city').value;
  const address = document.getElementById('address').value.trim();
  const product = document.getElementById('productSelect').value;

  if (!fname || !lname || !phone || !city || !address || !product) {
    alert('Veuillez remplir tous les champs obligatoires.');
    return;
  }
  document.getElementById('successModal').classList.add('show');
  document.getElementById('fname').value = '';
  document.getElementById('lname').value = '';
  document.getElementById('phone').value = '';
  document.getElementById('city').value = '';
  document.getElementById('address').value = '';
  document.getElementById('productSelect').value = '';
  document.getElementById('notes').value = '';
  clearSelection();
}

function closeModal() {
  document.getElementById('successModal').classList.remove('show');
}

renderProducts('tous');
</script>
</body>
</html>
